{
  "name": "attention-allocation",
  "category": "General",
  "purpose": "Optimize attention allocation across multiple tasks, contexts, and priorities.",
  "version": "2.0.0",
  "server": "ai-cognition",
  "whenToUse": "",
  "whenNotToUse": "",

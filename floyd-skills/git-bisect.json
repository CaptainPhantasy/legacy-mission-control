{
  "name": "git-bisect",
  "category": "General",
  "purpose": "Automated git bisect with test command execution to identify the exact commit that introduced a bug.",
  "version": "2.0.0",
  "server": "floyd-core",
  "whenToUse": "",
  "whenNotToUse": "",
  "schema": {
